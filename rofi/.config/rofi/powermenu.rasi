/* Power menu — Tokyo Night Storm */
@import "~/.config/rofi/config.rasi"

window {
    width:            200px;
    location:         north east;
    y-offset:         42;
    padding:          10;
    border-radius:    10px;
}

listview {
    lines:     7;
    columns:   1;
    scrollbar: false;
}

/* Hide the input bar for menu-only mode */
mainbox {
    children: [listview];
}

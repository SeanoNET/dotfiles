# kanshi — automatic monitor profile switching
# See `man kanshi` for configuration reference
# Use `swaymsg -t get_outputs` to find output names and modes

# Laptop only (undocked)
profile undocked {
    output eDP-1 enable mode 1920x1080@60Hz position 0,0 scale 1
}

